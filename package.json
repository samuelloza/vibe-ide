{
  "name": "vibe-ide",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "PORT=3100 NODE_ENV=development node server.mjs",
    "build": "next build",
    "start": "NODE_ENV=production node server.mjs",
    "lint": "npm run typecheck",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run build",
    "lsp:up": "docker compose -f ../vibe-lsp-server/docker-compose.yml up --build",
    "lsp:up:detached": "docker compose -f ../vibe-lsp-server/docker-compose.yml up --build -d",
    "lsp:down": "docker compose -f ../vibe-lsp-server/docker-compose.yml down",
    "lsp:logs": "docker compose -f ../vibe-lsp-server/docker-compose.yml logs -f"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "framer-motion": "^12.12.1",
    "monaco-editor": "^0.52.2",
    "next": "^15.3.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ws": "^8.20.1",
    "zustand": "^5.0.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
